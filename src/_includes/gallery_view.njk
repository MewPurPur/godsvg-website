<div class="gallery-view">
	<script>
		document.addEventListener("DOMContentLoaded", function() {
			const links = document.querySelectorAll(".gallery-view-image");
			const modal = document.querySelector(".gallery-modal")
			const modalClose = document.querySelector(".gallery-modal-close")
			const modalImage = document.querySelector(".gallery-modal-image")
			const modalDescription = document.querySelector(".gallery-modal-description")

			links.forEach(function(link) {
				link.addEventListener("click", function(e) {
					const image = this.querySelector("img");
					modal.style.display = "flex";
					document.body.style.overflow = "hidden";

					modalImage.src = image.src;
					modalDescription.innerHTML = image.dataset.desc;
				})
			});
			modalClose.addEventListener("click", function() {
				modal.style.display = "none";
				document.body.style.overflow = "";
			});
			window.addEventListener("keydown", function(event) {
				if (event.key === "Escape") {
					modal.style.display = "none";
					document.body.style.overflow = "";
				}
			});
			window.addEventListener("pointerdown", function(event) {
				if (event.target == modal) {
					modal.style.display = "none";
					document.body.style.overflow = "";
				}
			});
		});
	</script>
	<link rel="stylesheet" type="text/css" href="/styles/templates/gallery_view.scss">
	<div class="gallery-view-images">
		{% for image in images %}
			<button class="gallery-view-image">
				<img src="{{ image.src }}" class="gallery-view-image" data-desc="{{ image.desc }}" alt="{{ image.alt }}" loading="lazy" />
			</button>
		{% endfor %}
	</div>
</div>
<div class="gallery-modal">
	<div class="gallery-modal-content">
		<div class="gallery-modal-title-bar">
			<button class="gallery-modal-close">
				<span></span>
				<span></span>
			</button>
		</div>
		<div class="gallery-modal-main-content">
			<img class="gallery-modal-image" src="" alt="" loading="lazy" />
			<p class="gallery-modal-description"></p>
		</div>
	</div>
</div>
