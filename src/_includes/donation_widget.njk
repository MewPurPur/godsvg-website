<div class="donation-widget">
	<script>
		document.addEventListener("DOMContentLoaded", function() {
			const defaultMessage = document.getElementById("default-message");

			function hideAllDetails() {
				defaultMessage.style.display = "block";
				document.querySelectorAll(".platform-details").forEach(detail => {
					detail.style.display = "none";
				});
			}

			function showDetails(button) {
				hideAllDetails();
				defaultMessage.style.display = "none";
				const details = document.getElementById(button.id.replace("-btn", "-details"));
				if (details) {
					details.style.display = "block";
				}
			}

			hideAllDetails();

			document.querySelectorAll(".donation-button").forEach(button => {
				button.addEventListener("mouseenter", function() {
					showDetails(button);
				});

				button.addEventListener("focus", function() {
					showDetails(button);
				});

				button.addEventListener("mouseleave", function(e) {
					const relatedTarget = e.relatedTarget;
					if (!relatedTarget || !relatedTarget.classList.contains("donation-button")) {
						hideAllDetails();
					}
				});

				button.addEventListener("blur", function() {
					hideAllDetails();
				});
			});
		});
	</script>
	<link rel="stylesheet" type="text/css" href="/styles/templates/donation_widget.scss">

	<div class="donation-header">Donation platforms</div>

	<div class="donation-buttons">
		{% for platformName, platform in donationPlatforms %}
			<a href="{{platform.url}}" class="donation-button" id="{{platformName}}-btn">
				<img class="donation-platform-icon" src="{{platform.icon}}" alt="{{platformName}} logo">
			</a>
		{% endfor %}
	</div>

	<div class="platform-details-container">
		<div id="default-message" class="hover-info" style="display: block">
			Hover a platform for details
		</div>

		{% for platformName, platform in donationPlatforms %}
			<div class="platform-details" id="{{platformName}}-details">
				<div class="platform-name">{{platformName}}:</div>
				<ul class="platform-points">
					{% for pro in platform.pros %}
						<li class="list-pro">{{pro}}</li>
					{% endfor %}
					{% for con in platform.cons %}
						<li class="list-con">{{con}}</li>
					{% endfor %}
				</ul>
			</div>
		{% endfor %}
	</div>
</div>
